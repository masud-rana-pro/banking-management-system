      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/reports/branch?dateFrom=2026-04-01&dateTo=2026-04-30&branchId=2&requestedBy=SYSTEM"
      }
    },
    {
      "name": "13 Branch Report - CSV",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/reports/branch?dateFrom=2026-03-01&dateTo=2026-04-30&branchId=1&exportType=CSV&requestedBy=SYSTEM"
